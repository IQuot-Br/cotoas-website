import psutil

def detectar_jogo(processo_alvo="RobloxPlayerBeta.exe"):
    """Varre o sistema em busca do processo alvo e retorna (encontrado, pid)"""
    for processo in psutil.process_iter(['pid', 'name']):
        try:
            if processo.info['name'].lower() == processo_alvo.lower():
                return True, processo.info['pid']
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue
    return False, None
